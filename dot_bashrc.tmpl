# shellcheck shell=bash
# shellcheck disable=SC2034

# If not running interactively, don't do anything
case $- in
	*i*) ;;
	*) return ;;
esac

# Set editor variable
export EDITOR=vim

# Azure DevOps PAT (decrypted from encrypted chezmoi source at apply time)
export PERSONAL_ACCESS_TOKEN="{{ joinPath .chezmoi.sourceDir ".personal_access_token.age" | include | decrypt | trim | replace "\n" "" }}"

# Aliases
alias homelab='ssh -i ~/.ssh/id_homelab 192.168.1.10'

# Claude code: switch between local and cloud
claude-local() {
  ANTHROPIC_AUTH_TOKEN=ollama ANTHROPIC_API_KEY="" ANTHROPIC_BASE_URL=http://192.168.1.10:11434 claude --model qwen2.5-coder:7b "$@"
}
claude-cloud() {
  claude "$@"   # falls back to your normal Claude Code auth — no Ollama env vars set
}
